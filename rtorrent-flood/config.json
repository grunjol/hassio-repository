{
  "name": "rTorrent and Flood",
  "version": "0.1.15",
  "slug": "rtorrent-flood",
  "description": "rTorrent and Flood web UI add-on for Hass.io",
  "url": "https://github.com/grunjol/addon-rtorrent-flood",
  "init": false,
  "arch": ["amd64"],
  "hassio_api": true,
  "map": ["config:rw", "share:rw", "media:rw", "ssl"],
  "options": {
    "download_dir": "/media/Downloads",
    "max_upload_speed": 0,
    "max_download_speed": 0,
    "log_level": "info"
  },
  "ports": {
    "3000/tcp": 3000,
    "49184/tcp": 49184,
    "49184/udp": 49184
  },
  "ports_description": {
    "3000/tcp": "Flood UI interface",
    "49184/tcp": "rTorrent peers",
    "49184/udp": "rTorrent UDP peers"
  },
  "schema": {
    "download_dir": "str",
    "max_upload_speed": "int",
    "max_download_speed": "int",
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)"
  },
  "webui" : "http://[HOST]:[PORT:3000]/",
  "image": "ghcr.io/grunjol/addon-rtorrent-flood"
}
